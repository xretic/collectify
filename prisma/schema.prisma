generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                   Int                @id
    email                String             @unique
    passwordHash         String?
    avatarUrl            String             @default("")
    bannerUrl            String             @default("")
    username             String             @unique
    fullName             String
    description          String             @default("")
    githubId             String?            @unique
    googleId             String?            @unique
    createdAt            DateTime           @default(now())
    collections          Collection[]
    subscriptions        Follow[]           @relation("Subscriptions")
    followers            Follow[]           @relation("Followers")
    notifications        Notification[]     @relation("ReceivedNotifications")
    Notification         Notification[]
    sessions             Session[]
    favorites            Collection[]       @relation("FavoriteCollections")
    Comment              Comment[]
    chats                Chat[]
    messages             Message[]
    Verified             Verified?
    Moderator            Moderator?
    sanctions            AccountSanction[]  @relation("UserSanctions")
    issuedSanctions      AccountSanction[]  @relation("IssuedSanctions")
    moderationActions    ModerationAction[] @relation("ModerationActionsActor")
    moderationTargets    ModerationAction[] @relation("ModerationActionsTargetUser")
    reportsMade          Report[]           @relation("ReportsMade")
    reportsReceived      Report[]           @relation("ReportsReceived")
    reportsReviewed      Report[]           @relation("ReportsReviewed")
    impersonatedSessions Session[]          @relation("ImpersonatedSessions")
}

model Admin {
    id         Int      @id @default(autoincrement())
    userId     Int      @unique
    assignedBy Int      @default(0)
    createdAt  DateTime @default(now())
}

model Verified {
    id        Int      @id @default(autoincrement())
    userId    Int      @unique
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
}

model Moderator {
    id         Int      @id @default(autoincrement())
    userId     Int      @unique
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    assignedBy Int      @default(0)
    createdAt  DateTime @default(now())
}

model Chat {
    id        Int       @id @default(autoincrement())
    createdAt DateTime  @default(now())
    users     User[]
    messages  Message[]
}

model Message {
    id              Int      @id @default(autoincrement())
    chatId          Int
    userId          Int
    recipientUserId Int
    content         String
    read            Boolean  @default(false)
    createdAt       DateTime @default(now())

    chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
    user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    reports Report[]

    @@index([chatId, createdAt])
    @@index([userId, createdAt])
}

model Notification {
    id              Int              @id @default(autoincrement())
    senderUserId    Int?
    recipientUserId Int
    createdAt       DateTime         @default(now())
    isRead          Boolean          @default(false)
    type            NotificationType
    collectionId    Int?
    collection      Collection?      @relation(fields: [collectionId], references: [id])
    recipientUser   User             @relation("ReceivedNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)
    senderUser      User?            @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
}

model AccountSanction {
    id          Int           @id @default(autoincrement())
    userId      Int
    moderatorId Int?
    scope       SanctionScope
    reason      String        @default("")
    expiresAt   DateTime?
    revokedAt   DateTime?
    createdAt   DateTime      @default(now())

    user      User  @relation("UserSanctions", fields: [userId], references: [id], onDelete: Cascade)
    moderator User? @relation("IssuedSanctions", fields: [moderatorId], references: [id], onDelete: SetNull)

    @@index([userId, scope])
    @@index([revokedAt, expiresAt])
}

model ModerationAction {
    id                 Int      @id @default(autoincrement())
    actorId            Int?
    targetUserId       Int?
    targetCollectionId Int?
    targetCommentId    Int?
    action             String
    reason             String   @default("")
    metadata           Json?
    createdAt          DateTime @default(now())

    actor            User?       @relation("ModerationActionsActor", fields: [actorId], references: [id], onDelete: SetNull)
    targetUser       User?       @relation("ModerationActionsTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
    targetCollection Collection? @relation(fields: [targetCollectionId], references: [id], onDelete: SetNull)
    targetComment    Comment?    @relation(fields: [targetCommentId], references: [id], onDelete: SetNull)

    @@index([actorId, createdAt])
    @@index([targetUserId, createdAt])
}

model Report {
    id           Int           @id @default(autoincrement())
    reporterId   Int
    targetUserId Int
    messageId    Int?
    commentId    Int?
    collectionId Int?
    reason       String
    details      String        @default("")
    status       ReportStatus  @default(OPEN)
    verdict      ReportVerdict @default(PENDING)
    reviewedById Int?
    reviewedAt   DateTime?
    resolution   String        @default("")
    createdAt    DateTime      @default(now())

    reporter   User        @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
    targetUser User        @relation("ReportsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
    reviewedBy User?       @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
    message    Message?    @relation(fields: [messageId], references: [id], onDelete: SetNull)
    comment    Comment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
    collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

    @@index([status, createdAt])
    @@index([targetUserId, createdAt])
    @@index([messageId])
    @@index([commentId])
    @@index([collectionId])
}

model Follow {
    followerId  Int
    followingId Int
    follower    User @relation("Subscriptions", fields: [followerId], references: [id], onDelete: Cascade)
    following   User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

    @@id([followerId, followingId])
}

model Session {
    id                 String   @id
    userId             Int
    impersonatorUserId Int?
    expiresAt          DateTime
    user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    impersonator       User?    @relation("ImpersonatedSessions", fields: [impersonatorUserId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([impersonatorUserId])
}

model Collection {
    id               Int                @id @default(autoincrement())
    name             String
    lowerCaseName    String
    description      String             @default("")
    bannerUrl        String
    category         String
    userId           Int?
    createdAt        DateTime           @default(now())
    User             User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
    items            Item[]
    likes            Like[]
    comments         Comment[]
    addedToFavorite  User[]             @relation("FavoriteCollections")
    private          Boolean            @default(false)
    Notification     Notification[]
    ModerationAction ModerationAction[]
    reports          Report[]
}

model Comment {
    id               Int                @id @default(autoincrement())
    User             User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId           Int
    collectionId     Int
    text             String
    Collection       Collection         @relation(fields: [collectionId], references: [id], onDelete: Cascade)
    createdAt        DateTime           @default(now())
    ModerationAction ModerationAction[]
    reports          Report[]
}

model Like {
    id           Int        @id @default(autoincrement())
    userId       Int
    collectionId Int
    Collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
    createdAt    DateTime   @default(now())
}

model Item {
    id           Int         @id @default(autoincrement())
    title        String
    description  String
    collectionId Int?
    sourceUrl    String?
    imageUrl     String?
    order        Int
    Collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

    @@index([collectionId, order])
}

enum NotificationType {
    FOLLOW
    LIKE
    COMMENT
    FAVORITE
}

enum SanctionScope {
    ACCOUNT
    COMMENTS
    MESSENGER
}

enum ReportStatus {
    OPEN
    CLOSED
}

enum ReportVerdict {
    PENDING
    NO_VIOLATION
    INSUFFICIENT_EVIDENCE
    DUPLICATE
    GUILTY
}
